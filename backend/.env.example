MONGODB_URI=mongodb://127.0.0.1:27017/chisteteca
JWT_SECRET=change_this_in_real_environments
PORT=5000
# Comma-separated list of allowed origins (e.g. for custom domain + Cloudflare Pages)
FRONTEND_URL=http://localhost:3000
# Production example: https://chisteteca-frontend.pages.dev,https://chisteteca.es,https://www.chisteteca.es
# Canonical URL for sharing (og:url, redirects). Use your custom domain, not pages.dev.
# CANONICAL_URL=https://chisteteca.es
# Public backend URL (optional). Set when behind reverse proxy so og:image URLs are correct.
# BACKEND_URL=https://api.chisteteca.com

# Cloudflare R2 - almacenamiento persistente de avatares (necesario en Railway, etc.)
# Sin R2, los avatares se guardan en disco (se pierden en deploys).
# Crear bucket en Cloudflare Dashboard > R2 > Create bucket
# Crear API token en R2 > Manage R2 API Tokens
# Habilitar acceso público al bucket y copiar la URL (ej: https://pub-xxx.r2.dev)
# R2_ACCOUNT_ID=tu_account_id
# R2_ACCESS_KEY_ID=xxx
# R2_SECRET_ACCESS_KEY=xxx
# R2_BUCKET_NAME=chisteteca-avatars
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

NODE_ENV=development
