MONGODB_URI=mongodb://127.0.0.1:27017/chisteteca
JWT_SECRET=change_this_in_real_environments
PORT=5000
# Comma-separated list of allowed origins (e.g. for custom domain + Cloudflare Pages)
FRONTEND_URL=http://localhost:3000
# Production example: https://chisteteca-frontend.pages.dev,https://chisteteca.es,https://www.chisteteca.es
# Canonical URL for sharing (og:url, redirects). Use your custom domain, not pages.dev.
# CANONICAL_URL=https://chisteteca.es
# Public backend URL (para og:image y enlaces de confirmación de newsletter)
# En Railway: https://chisteteca-production.up.railway.app
# BACKEND_URL=https://tu-backend.railway.app

# Newsletter (Resend Broadcasts). Crear segmento en Resend Dashboard > Audiences.
# RESEND_NEWSLETTER_SEGMENT_ID=xxx

# Resend: dos keys opcionales (más seguro por principio de mínimo privilegio).
# RESEND_API_KEY: Sending access - solo emails.send (verificación, notificaciones, newsletter confirmación).
# RESEND_API_KEY_FULL: Full access - broadcasts, contacts, segments. Necesario para el digest semanal.
# Si solo usas una key, pon RESEND_API_KEY con Full access y omitir RESEND_API_KEY_FULL.

# Cloudflare R2 - almacenamiento persistente de avatares (necesario en Railway, etc.)
# Sin R2, los avatares se guardan en disco (se pierden en deploys).
# Crear bucket en Cloudflare Dashboard > R2 > Create bucket
# Crear API token en R2 > Manage R2 API Tokens
# Habilitar acceso público al bucket y copiar la URL (ej: https://pub-xxx.r2.dev)
# R2_ACCOUNT_ID=tu_account_id
# R2_ACCESS_KEY_ID=xxx
# R2_SECRET_ACCESS_KEY=xxx
# R2_BUCKET_NAME=chisteteca-avatars
# R2_PUBLIC_URL=https://pub-xxx.r2.dev

NODE_ENV=development

# Email del admin para notificaciones de revisión (cuando hay chistes o categorías pendientes)
# ADMIN_REVIEW_EMAIL=guillotiname@gmail.com

# Email (verificación de cuenta, notificaciones, newsletter).
# Opción 1 - Resend API (recomendado, usa HTTPS, no bloqueado por Railway):
# RESEND_API_KEY=re_xxxxxxxxx          # Sending access (emails.send)
# RESEND_API_KEY_FULL=re_yyyyyyyyy     # Full access (broadcasts, contacts, segments). Opcional: si no existe usa RESEND_API_KEY
# RESEND_FROM="Chisteteca" <noreply@chisteteca.es>
# Opción 2 - SMTP (fallback):
# SMTP_HOST=smtp.example.com
# SMTP_PORT=587
# SMTP_SECURE=false
# SMTP_USER=
# SMTP_PASS=
# SMTP_FROM="Chisteteca" <noreply@chisteteca.es>
