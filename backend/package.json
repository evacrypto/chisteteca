{
  "name": "chisteteca-backend",
  "version": "1.0.0",
  "description": "Backend API for Chisteteca - Humor Platform",
  "main": "src/server.js",
  "type": "module",
  "scripts": {
    "start": "node src/server.js",
    "dev": "nodemon src/server.js",
    "seed": "node src/utils/seed.js",
    "backfill:content-creators": "node src/utils/backfill-content-creators.js",
    "clean:orphan-content": "node src/utils/clean-orphan-content.js",
    "qa:handoff": "npm run seed && npm run qa:scan-legacy && npm run qa:e2e",
    "qa:e2e": "powershell -ExecutionPolicy Bypass -File qa/e2e-user-admin.ps1",
    "qa:scan-legacy": "powershell -ExecutionPolicy Bypass -File qa/scan-legacy-author-refs.ps1",
    "test": "echo \"Error: no test specified\" && exit 1"
  },
  "keywords": ["humor", "jokes", "comedy"],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "express": "^4.18.2",
    "mongoose": "^8.0.0",
    "dotenv": "^16.3.1",
    "cors": "^2.8.5",
    "bcryptjs": "^2.4.3",
    "jsonwebtoken": "^9.0.2",
    "multer": "^1.4.5-lts.1",
    "express-validator": "^7.0.1",
    "helmet": "^7.1.0",
    "morgan": "^1.10.0"
  },
  "devDependencies": {
    "nodemon": "^3.0.1"
  }
}
